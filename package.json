{
  "name": "@rubix-studios-pty-ltd/rubix-redis-bridge",
  "title": "Rubix Redis Bridge",
  "version": "1.1.1",
  "description": "Secure Rust HTTP bridge for Redis with Upstash Redis, Ratelimit, and Realtime compatibility, scoped command policy, Docker deployment, and SDK tests.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "author": "Rubix Studios <hello@rubixstudios.com.au> (https://rubixstudios.com.au)",
  "homepage": "https://rubixstudios.com.au",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubix-studios-pty-ltd/rubix-redis-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/rubix-studios-pty-ltd/rubix-redis-bridge/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "maintainers": [
    {
      "name": "Rubix Studios",
      "email": "hello@rubixstudios.com.au",
      "url": "https://rubixstudios.com.au"
    }
  ],
  "keywords": [
    "redis",
    "rust",
    "http",
    "redis-client",
    "redis-proxy",
    "upstash",
    "upstash-redis",
    "upstash-realtime",
    "realtime",
    "docker",
    "docker-image",
    "axum",
    "tokio",
    "api-bridge",
    "secure-by-default",
    "self-hosted",
    "infrastructure",
    "devops"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:rust": "cargo test",
    "test:sdk": "node --test tests/sdk/upstash.test.mjs",
    "test:all": "cargo test && node --test tests/sdk/upstash.test.mjs",
    "update:rust": "cargo update && cargo fmt",
    "update:deps": "pnpm update --latest && pnpm install && pnpm dedupe"
  },
  "engines": {
    "node": "24.x || 25.x",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@upstash/ratelimit": "latest",
    "@upstash/realtime": "1.0.4",
    "@upstash/redis": "latest",
    "ioredis": "^5.11.1",
    "undici": "^8.8.0"
  },
  "packageManager": "pnpm@11.15.1"
}
