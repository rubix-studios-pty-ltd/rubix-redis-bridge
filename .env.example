RRB_MODE=env
RRB_PORT=8080

REDIS_TOKEN=replace-with-redis-password
RRB_CONNECTION_STRING=redis://default:replace-with-redis-password@redis:6379

RRB_TOKEN=replace-with-strong-http-token
# RRB_HASH_TOKEN=replace-with-hmac-key
RRB_METRICS_TOKEN=replace-with-strong-metrics-token

# Optional. Enable only when the bridge is behind trusted reverse proxies.
# When disabled, forwarded headers are ignored and the TCP peer IP is used.
RRB_TRUST_PROXY_HEADERS=false

# Required when RRB_TRUST_PROXY_HEADERS=true.
# Only include proxies that overwrite or sanitize forwarded headers.
RRB_TRUSTED_PROXIES=127.0.0.1/32

RRB_MAX_CONCURRENCY=1024
RRB_OPERATION_LIMIT=100
RRB_CONNECTION_SHARDS=4

# Optional strict allowlist. If omitted, the bridge uses a conservative safe default.
# If set to an empty value, startup fails closed.
RRB_ALLOWED_COMMANDS=PING,GET,GETDEL,MGET,SET,SETEX,DEL,EXISTS,EXPIRE,TTL,INCR,DECR,HGET,HSET,HDEL,HMGET,HGETALL,ZINCRBY,EVALSHA,EVAL,SCRIPT

RRB_UPSTASH_RATELIMIT=true

RRB_AUTH_LOCKOUT_FAILURES=10
RRB_AUTH_LOCKOUT_WINDOW_SECONDS=300
RRB_AUTH_LOCKOUT_SECONDS=300
RRB_AUTH_LOCKOUT_MAX_ENTRIES=65536

RRB_MAX_BODY_BYTES=1048576
RRB_MAX_PIPELINE_COMMANDS=1000
RRB_MAX_COMMAND_ARGS=256
RRB_MAX_ARG_BYTES=262144
RRB_MAX_RESPONSE_BYTES=10485760

RRB_ACQUIRE_TIMEOUT_MS=100
RRB_REQUEST_TIMEOUT_MS=5000